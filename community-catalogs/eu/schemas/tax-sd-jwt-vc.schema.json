{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "tax_number": {
      "type": "string",
      "description": "Tax Number"
    },
    "affiliation_country": {
      "type": "string",
      "description": "Affiliation Country"
    },
    "registered_given_name": {
      "type": "string",
      "description": "Registered Given Name"
    },
    "registered_family_name": {
      "type": "string",
      "description": "Registered Family Name"
    },
    "resident_address": {
      "type": "string",
      "description": "Resident Address"
    },
    "birth_date": {
      "type": "string",
      "format": "date",
      "description": "Birth Date"
    },
    "church_tax_ID": {
      "type": "string",
      "description": "Church Tax ID"
    },
    "iban": {
      "type": "string",
      "description": "IBAN"
    },
    "credential_type": {
      "type": "string",
      "description": "Credential Type"
    },
    "issuance_date": {
      "type": "string",
      "description": "Issuance Date"
    },
    "expiry_date": {
      "type": "string",
      "description": "Expiry Date"
    },
    "issuing_authority": {
      "type": "string",
      "description": "Issuing Authority"
    },
    "issuing_jurisdiction": {
      "type": "string",
      "description": "Issuing Jurisdiction"
    },
    "issuing_country": {
      "type": "string",
      "description": "Issuing Country"
    }
  },
  "additionalProperties": true,
  "required": [
    "tax_number",
    "affiliation_country",
    "registered_given_name",
    "registered_family_name",
    "resident_address",
    "birth_date",
    "credential_type",
    "issuance_date",
    "expiry_date",
    "issuing_authority",
    "issuing_country"
  ],
  "$id": "https://eudi.example.org/schemas/tax-sd-jwt-vc.schema.json",
  "title": "Tax Number (SD-JWT VC)",
  "vct": "urn:eu.europa.ec.eudi:tax:1"
}
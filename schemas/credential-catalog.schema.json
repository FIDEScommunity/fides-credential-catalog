{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fides.community/schemas/credential-catalog/v1",
  "title": "FIDES Credential Catalog Schema",
  "description": "Schema for credential catalog entries. Provider profile is defined in the FIDES organization catalog; this file references it via orgId.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "orgId", "credentials"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://fides.community/schemas/credential-catalog/v1"
    },
    "orgId": {
      "type": "string",
      "pattern": "^org:[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Organization catalog id. Canonical provider name, DID, website, logo, and contact come from the organization catalog aggregated data."
    },
    "credentials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Credential"
      }
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "EntityReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "CredentialReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cred:[a-z0-9]+:[a-z0-9-]+:[a-z0-9-]+$"
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "VocabularyReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "authority": {
          "$ref": "#/$defs/EntityReference"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "Credential": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "authority",
        "subjectType",
        "vcFormat",
        "version",
        "schemaUrl",
        "schemaType"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cred:[a-z0-9]+:[a-z0-9-]+:[a-z0-9-]+$",
          "description": "Format: cred:<authorityCode>:<credentialKey>:<formatCode>"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "shortDescription": {
          "type": "string"
        },
        "authority": {
          "$ref": "#/$defs/EntityReference"
        },
        "subjectType": {
          "type": "string",
          "enum": ["Person", "Organization", "Product", "Dataset", "Software", "Document"]
        },
        "vcFormat": {
          "type": "string",
          "enum": ["sd_jwt_vc", "mdoc", "vcdm_1_1", "vcdm_2_0", "acdc", "other"]
        },
        "nativeIdentifier": {
          "type": "string"
        },
        "nativeIdentifierType": {
          "type": "string",
          "enum": ["vct", "docType", "type", "schema_said", "other"]
        },
        "schemaUrl": {
          "type": "string",
          "format": "uri"
        },
        "schemaType": {
          "type": "string",
          "enum": ["JSON Schema", "JSON-LD Context", "ISO Data Model", "ACDC Schema", "Other"]
        },
        "rulebookUrl": {
          "type": "string",
          "format": "uri"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "extends": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CredentialReference"
          },
          "uniqueItems": true
        },
        "vocabularies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/VocabularyReference"
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    }
  }
}

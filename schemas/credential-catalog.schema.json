{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fides.community/schemas/credential-catalog/v1",
  "title": "FIDES Credential Catalog Schema",
  "description": "Schema for credential catalog entries. Provider profile is defined in the FIDES organization catalog; this file references it via orgId.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "orgId", "credentials"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://fides.community/schemas/credential-catalog/v1"
    },
    "orgId": {
      "type": "string",
      "pattern": "^org:[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Organization catalog id. Canonical provider name, DID, website, logo, and contact come from the organization catalog aggregated data."
    },
    "credentials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Credential"
      }
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "EntityReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "CredentialReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cred:[a-z0-9]+:[a-z0-9-]+:[a-z0-9-]+$"
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "VocabularyReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "authority": {
          "$ref": "#/$defs/EntityReference"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "CredentialSectorCode": {
      "type": "string",
      "enum": [
        "public_sector",
        "finance",
        "trade",
        "supply_chain",
        "manufacturing",
        "energy",
        "agriculture",
        "food",
        "retail",
        "healthcare",
        "education",
        "construction",
        "mobility",
        "digital"
      ],
      "description": "Must stay in sync with OrganizationSectorCode in fides-organization-catalog (organization-catalog.schema.json)."
    },
    "CredentialEcosystemCode": {
      "type": "string",
      "enum": [
        "eudi_wallet",
        "uncefact",
        "gaia_x",
        "open_badges",
        "iso_mdl",
        "india_stack",
        "swiyu",
        "vlei"
      ],
      "description": "Closed ecosystem taxonomy for credential classification."
    },
    "CredentialThemeCode": {
      "type": "string",
      "enum": [
        "person_identity",
        "organizational_identity",
        "payments",
        "compliance_reporting",
        "trade_documents",
        "education",
        "digital_product_passports",
        "dataspaces",
        "agentic_ai"
      ],
      "description": "Cross-sector use-case themes for discovery (optional on each credential)."
    },
    "Credential": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "authority",
        "subjectType",
        "vcFormat",
        "version",
        "schemaUrl",
        "schemaType",
        "sectors",
        "ecosystems"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cred:[a-z0-9]+:[a-z0-9-]+:[a-z0-9-]+$",
          "description": "Format: cred:<authorityCode>:<credentialKey>:<formatCode>"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "shortDescription": {
          "type": "string"
        },
        "authority": {
          "$ref": "#/$defs/EntityReference"
        },
        "subjectType": {
          "type": "string",
          "enum": ["Person", "Organization", "Product", "Dataset", "Software", "Document"]
        },
        "vcFormat": {
          "type": "string",
          "enum": [
            "sd_jwt_vc",
            "mdoc",
            "jwt_vc",
            "vcdm_1_1",
            "vcdm_2_0",
            "anoncreds",
            "idemix",
            "apple_wallet_pass",
            "google_wallet_pass",
            "acdc"
          ]
        },
        "nativeIdentifier": {
          "type": "string"
        },
        "nativeIdentifierType": {
          "type": "string",
          "enum": ["vct", "docType", "type", "schema_said", "other"]
        },
        "schemaUrl": {
          "type": "string",
          "format": "uri"
        },
        "schemaType": {
          "type": "string",
          "enum": ["JSON Schema", "JSON-LD Context", "ISO Data Model", "ACDC Schema", "Other"]
        },
        "rulebookUrl": {
          "type": "string",
          "format": "uri"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "extends": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CredentialReference"
          },
          "uniqueItems": true
        },
        "vocabularies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/VocabularyReference"
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "sectors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "description": "One or more sectors from the same closed list as the organization catalog.",
          "items": { "$ref": "#/$defs/CredentialSectorCode" }
        },
        "ecosystems": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "description": "One or more ecosystems this credential type is associated with.",
          "items": { "$ref": "#/$defs/CredentialEcosystemCode" }
        },
        "themes": {
          "type": "array",
          "uniqueItems": true,
          "description": "Optional use-case themes for discovery and filtering (orthogonal to sectors/ecosystems).",
          "items": { "$ref": "#/$defs/CredentialThemeCode" }
        }
      }
    }
  }
}
